{
  "name": "pagewise",
  "version": "0.0.0",
  "private": true,
  "description": "Browser extension that gives blind users a faster, structured way to understand any web page, powered by the Claude API.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
